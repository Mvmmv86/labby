LABBY_ENVIRONMENT=development
LABBY_DATABASE_URL=postgresql+psycopg://labby:labby@localhost:5432/labby
LABBY_DATABASE_POOL_SIZE=10
LABBY_DATABASE_MAX_OVERFLOW=20
LABBY_DATABASE_POOL_TIMEOUT_SECONDS=30
LABBY_DATABASE_POOL_RECYCLE_SECONDS=1800
LABBY_REDIS_URL=redis://localhost:6379/0
LABBY_JWT_SECRET=change-me-in-production
LABBY_JWT_ISSUER=labby-api
LABBY_JWT_AUDIENCE=labby-app
LABBY_ACCESS_TOKEN_EXPIRE_MINUTES=30
LABBY_REFRESH_TOKEN_EXPIRE_DAYS=30
LABBY_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://app.labby.com.br
LABBY_DOCS_ENABLED=true
LABBY_TIMEZONE=America/Sao_Paulo
